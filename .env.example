# Postgres. En local, DATABASE_URL y DIRECT_URL pueden ser iguales.
# En Supabase: DATABASE_URL = pooler (Supavisor, puerto 6543, ?pgbouncer=true&connection_limit=1)
#              DIRECT_URL   = conexión de sesión (puerto 5432, para migraciones)
DATABASE_URL="postgresql://user:pass@localhost:5432/mevradar?schema=public"
DIRECT_URL="postgresql://user:pass@localhost:5432/mevradar?schema=public"
SESSION_SECRET="cambiar-por-32+chars-aleatorios (openssl rand -hex 32)"
MEV_CRED_KEY="64-hex-chars-para-aes-256-gcm (openssl rand -hex 32)"
MEV_BASE_URL="https://mev.scba.gov.ar"
